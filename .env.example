# Database
DATABASE_URL="file:./prisma/dev.db"

# Authentication
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (Resend)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Business Register API (Uzņēmumu Reģistrs) - Production Environment
BR_AUTH_URL="https://ha.viss.gov.lv/STS/VISS.Pfas.STS/oauth2/token"
BR_CONSUMER_KEY="your-consumer-key"
BR_CONSUMER_SECRET="your-consumer-secret"
BR_TRANSACTION_API_URL="https://vissapi.viss.gov.lv/ApiManagement.TransactionApi/transactions"
BR_PINGPONG_URL="https://vissapi.viss.gov.lv/ApiManagement.TransactionApi/pingpong"
BR_ESERVICE_ID="URN:IVIS:100001:EP.DA-DA616-V1-0"
BR_AUTHORITY_IDENT="FP_RPAVARS"
BR_API_GATEWAY_URL="https://apigw.viss.gov.lv"

# PFAS Certificate (required for live API)
BR_CERTIFICATE_PATH="/path/to/your/certificate.pfx"
BR_CERTIFICATE_PASSWORD="your-certificate-password"

# Set to "false" after obtaining Consumer Key/Secret from developer portal
BR_USE_MOCK_DATA="true"

# Site Maintenance
SITE_ENABLED="true"
