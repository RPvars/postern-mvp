{
  "name": "posterns-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "kill": "lsof -ti:3000 | xargs kill -9 || true",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "import:tax": "tsx scripts/import-vid-tax-data.ts",
    "import:insolvency": "tsx scripts/import-insolvency-data.ts",
    "import:rating": "tsx scripts/import-taxpayer-rating.ts",
    "import:vat": "tsx scripts/import-vat-payers.ts",
    "import:nace": "tsx scripts/import-nace-codes.ts",
    "import:stateaid": "tsx scripts/import-state-aid.ts",
    "import:names": "tsx scripts/import-name-history.ts",
    "import:reorganizations": "tsx scripts/import-reorganizations.ts",
    "import:register": "tsx scripts/import-register.ts",
    "import:members": "tsx scripts/import-members.ts",
    "import:officers": "tsx scripts/import-officers.ts",
    "import:beneficial-owners": "tsx scripts/import-beneficial-owners.ts",
    "import:stockholders": "tsx scripts/import-stockholders.ts",
    "import:financial": "tsx scripts/import-financial-data.ts",
    "import:people": "npm run import:register && npm run import:members && npm run import:officers && npm run import:beneficial-owners && npm run import:stockholders",
    "import:all": "npm run import:nace && npm run import:tax && npm run import:insolvency && npm run import:rating && npm run import:vat && npm run import:stateaid && npm run import:names && npm run import:reorganizations && npm run import:people && npm run import:financial",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.32.1",
    "@vercel/speed-insights": "^1.2.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.553.0",
    "next": "16.0.1",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.5.6",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.3.0",
    "resend": "^6.5.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.8",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
